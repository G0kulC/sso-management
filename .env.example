# ──────────────────────────────────────────────
# SSO Identity Management System - Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────
# Database (PostgreSQL)
# DATABASE_URL=postgresql://db_user:db_password@localhost:5432/db_name
DATABASE_URL=postgresql://sso_user:sso_password@localhost:5432/sso_db

# JWT Security — CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkey-change-in-production-use-256bit-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
APP_NAME=SSO Identity Management System
APP_VERSION=1.0.0
DEBUG=True

# CORS Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
